{
  "name": "@f5-sales-demo/docs-theme",
  "version": "3.9.1",
  "description": "F5 Distributed Cloud branded Starlight documentation theme",
  "type": "module",
  "bin": {
    "docs-translate": "./bin/translate.mjs"
  },
  "license": "MIT",
  "homepage": "https://f5-sales-demo.github.io/docs-theme",
  "repository": {
    "type": "git",
    "url": "https://github.com/f5-sales-demo/docs-theme"
  },
  "bugs": {
    "url": "https://github.com/f5-sales-demo/docs-theme/issues"
  },
  "exports": {
    ".": "./index.ts",
    "./fonts/font-face.css": "./fonts/font-face.css",
    "./styles/custom.css": "./styles/custom.css",
    "./components/Banner.astro": "./components/Banner.astro",
    "./components/EditLink.astro": "./components/EditLink.astro",
    "./components/Footer.astro": "./components/Footer.astro",
    "./components/SiteTitle.astro": "./components/SiteTitle.astro",
    "./components/MarkdownContent.astro": "./components/MarkdownContent.astro",
    "./assets/f5-logo.svg": "./assets/f5-logo.svg",
    "./assets/github-avatar.png": "./assets/github-avatar.png",
    "./assets/f5-distributed-cloud.svg": "./assets/f5-distributed-cloud.svg",
    "./config": "./config.ts",
    "./route-middleware": "./route-middleware.ts",
    "./src/plugins/remark-mermaid.mjs": "./src/plugins/remark-mermaid.mjs",
    "./components/Icon.astro": "./components/Icon.astro",
    "./components/LinkCard.astro": "./components/LinkCard.astro",
    "./components/Screenshot.astro": "./components/Screenshot.astro",
    "./src/utils/resolve-icon.ts": "./src/utils/resolve-icon.ts",
    "./src/i18n/locales.ts": "./src/i18n/locales.ts",
    "./src/i18n/translator.ts": "./src/i18n/translator.ts",
    "./src/i18n/prompt.ts": "./src/i18n/prompt.ts",
    "./src/utils/localize-ecosystem-href.ts": "./src/utils/localize-ecosystem-href.ts"
  },
  "files": [
    "index.ts",
    "config.ts",
    "route-middleware.ts",
    "astro.config.mjs",
    "bin/",
    "fonts/",
    "styles/",
    "assets/",
    "components/",
    "src/"
  ],
  "keywords": [
    "starlight",
    "theme",
    "astro",
    "withastro",
    "starlight-theme",
    "f5",
    "f5xc",
    "documentation",
    "docs-theme"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "peerDependencies": {
    "@astrojs/markdown-remark": ">=7.0.0",
    "@astrojs/starlight": ">=0.38.0",
    "@f5-sales-demo/icons-f5-brand": "*",
    "@f5-sales-demo/icons-f5xc": "*",
    "@f5-sales-demo/icons-hashicorp-flight": "*",
    "@iconify-json/carbon": "*",
    "@iconify-json/lucide": "*",
    "@iconify-json/mdi": "*",
    "@iconify-json/ph": "*",
    "@iconify-json/tabler": "*",
    "astro": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "@iconify-json/lucide": {
      "optional": true
    },
    "@iconify-json/carbon": {
      "optional": true
    },
    "@iconify-json/mdi": {
      "optional": true
    },
    "@iconify-json/ph": {
      "optional": true
    },
    "@iconify-json/tabler": {
      "optional": true
    },
    "@f5-sales-demo/icons-f5-brand": {
      "optional": true
    },
    "@f5-sales-demo/icons-f5xc": {
      "optional": true
    },
    "@f5-sales-demo/icons-hashicorp-flight": {
      "optional": true
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.0",
    "@astrojs/react": "^6.0.0",
    "@f5-sales-demo/i18n-core": "^1.0.0",
    "@f5-sales-demo/starlight-llms-txt": "1.3.1",
    "@f5-sales-demo/starlight-mega-menu": "^2.0.0",
    "gray-matter": "^4.0.3",
    "remark-code-import": "^1.2.0",
    "starlight-heading-badges": "^0.7.0",
    "starlight-image-zoom": "^0.15.0",
    "starlight-openapi": "^0.26.0",
    "starlight-page-actions": "^0.6.0",
    "starlight-plugin-icons": "^1.1.3",
    "starlight-scroll-to-top": "^1.0.1",
    "starlight-videos": "^0.5.0",
    "unist-util-visit": "^5.0.0"
  }
}
