---
interface Props {
  light?: string;
  dark?: string;
  alt: string;
  width?: number;
  height?: number;
}

const { light, dark, alt, width, height } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolve = (src?: string) => src && src.startsWith('/') ? `${base}${src}` : src;

const lightSrc = resolve(light);
const darkSrc = resolve(dark);
const hasBoth = lightSrc && darkSrc;
---

{hasBoth ? (
  <div class="screenshot-pair">
    <img src={lightSrc} alt={alt} width={width} height={height} class="screenshot-light" />
    <img src={darkSrc} alt={alt} width={width} height={height} class="screenshot-dark" />
  </div>
) : (
  <div class="screenshot-pair">
    <img src={lightSrc || darkSrc} alt={alt} width={width} height={height} />
  </div>
)}
